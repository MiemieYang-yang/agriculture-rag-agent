# Qwen3 API（阿里云百炼平台）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.5-27b

# 向量模型路径（本地）或名称（自动下载）
BGE_MODEL_NAME=BAAI/bge-m3

# ChromaDB 持久化路径
CHROMA_PERSIST_DIR=./vectorstore/chroma_db
CHROMA_COLLECTION=agri_knowledge

# 检索参数
RETRIEVAL_TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64